library("RSelenium")
library("wdman")
library("netstat")
library("stringr")
library("reshape2")
library("tidyverse")
library("readr")



# A script for scrapping weather data since 2009 for nea zichni. The location varies. 


#selenium(retcommand = T, check = T)
#binman::list_versions("chromedriver")

rD <- rsDriver(browser="chrome", 
               chromever = "latest",
               verbose = F,
               port = free_port())

remDR <- rD$client
#remDR$open()

url = "https://www.worldweatheronline.com/nea-zichni-weather-averages/central-macedonia/gr.aspx"
#url = "https://www.worldweatheronline.com/regensburg-weather-averages/bayern/de.aspx"
remDR$navigate(url)

place = "zichni"

Sys.sleep(15)

#close cookies settings by rejecting all.
remDR$findElement(using = 'xpath', "//span[text() = 'MORE OPTIONS']")$clickElement()
Sys.sleep(2)
remDR$findElement(using = 'xpath', "//button[text() = 'REJECT ALL']")$clickElement()
Sys.sleep(2)
remDR$findElement(using = 'xpath', "//button[text() = 'SAVE & EXIT']")$clickElement()
#remDR$findElement(using = 'xpath', "//button[text() = 'SAVE & EXIT']")$clickElement()


#finding elements with e.g id = container_vis and looks inside the sequence div -> ssvg ->  g ->  g -> for path.
# The path contains the attribte aria-label as a text giving the information/data. We are after that.
#Mote that it finds more than it should, such as container 1 values and needs filtering. 
#By changing the id one has access to different data.

#Make case specific paths based on target data.
scrap_data = c("temperature", "pressure", "rain", "sunhours", "clouds", "Snow", "wind")

#element = "rain"

for (element in scrap_data) {

if (element == "temperature"){
 webElems <- remDR$findElements(using = 'css selector', '#container_temp > div >svg > g > g >path')
 col_select <- c("Date",  "Max Temp (°c)", "Avg Temp (°c)" ,"Min Temp (°c)")
 col_names <- c("Date",  "Max Temp", "Avg Temp" ,"Min Temp")
  } else if (element == "wind"){
  webElems <- remDR$findElements(using = 'css selector', '#container_wind > div >svg > g > g >path')
  col_select <- c("Date",  "Max Wind (kmph)", "Avg Wind (kmph)", "Avg Gust (kmph)")
  col_names <- c("Date",  "Max Wind", "Avg Wind" ,"Avg Gust")
  } else if (element == "rain"){
 webElems <- remDR$findElements(using = 'css selector', '#container_rain > div >svg > g > g >path')
 col_names <- c("Date",  "Rain")
 } else if (element == "Snow"){
 webElems <- remDR$findElements(using = 'css selector', '#container_snow > div >svg > g > g >path')
 col_names <- c("Date",  "Snow")
 } else if (element == "pressure"){
   webElems <- remDR$findElements(using = 'css selector', '#container_pressure > div >svg > g > g >path')
   col_names <- c("Date",  "Pressure")
 } else if (element == "sunhours"){
   webElems <- remDR$findElements(using = 'css selector', '#container_sun > div >svg > g > g >path')
   col_names <- c("Date",  "Sun Hours")
 } else if (element == "clouds"){
   webElems <- remDR$findElements(using = 'css selector', '#container_cl_hu > div >svg > g > g >path')
   col_names <- c("Date",  "Clouds")
 }

# Check the length
length(webElems)


# read out the text given by attribute aria-label and pass it to a list
attr_list <- unlist(lapply(webElems, function(x) x$getElementAttribute('aria-label')))
#attr_list

#split the text in five parts and create a matrix out of it
text_matrix <- str_split_fixed(attr_list, " ", 5)
text_matrix
#sum(is.na(text_matrix))

#text_matrix[,4]


text_df <- as.data.frame(text_matrix)
colnames(text_df) <- c("day", "month", "year", "value", "type")
#tail(text_df)
#sum(is.na(text_df))

text_df$year <- gsub(",","",text_df$year)
text_df$value <- gsub(",","",text_df$value)
text_df$value <- substr(text_df$value, 1, nchar(text_df$value)-1)
text_df$type <- substr(text_df$type, 1, nchar(text_df$type)-1)
text_df$value <- as.numeric(text_df$value) #<- as.numeric(substr(text_df$value, 1, nchar(text_df$value)-1))

text_df$Date <-with(text_df, paste('01', month,year, sep="-"))

text_df$Date <- as.Date(text_df$Date, format = "%d-%B-%Y")
text_df%>% arrange(Date)
#tail(text_df)


if (element == "wind" || element == "temperature"){
  text_df<- text_df%>% filter(type != "Navigator 1") %>% select(c("Date","value", "type"))
  df <-dcast(text_df, Date ~ type)%>% arrange(Date)%>%select(col_select)
  colnames(df) <- col_names
  print(tail(df))
  write_csv(df, paste0(element,"_",place,".csv"))

}else{
  text_df<- text_df%>% filter(type == "Navigator 1") %>% select(c("Date","value"))
  colnames(text_df) <- col_names
  print(tail(text_df))
  write_csv(text_df, paste0(element,"_",place,".csv"))
}

print(paste("scrapping for", element, "Done!"))

}
print("All scrapping done, finished!")


#terminate the task 
system("taskkill /im java.exe /f")

